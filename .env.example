# Copy to .env locally for testing. On Zeabur, set these in the dashboard.

# === fal.ai (generate_image 用,畫澈澈本人最準) ===
FAL_API_KEY=fal_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# === OpenAI gpt-image-2 (generate_image_gpt 用,泛用:手帳/日曆/場景/排版) ===
# 需付費 OpenAI 帳號,且要先在 console 做 Organization Verification 才能用 gpt-image 系列。
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 想換模型再開:gpt-image-2 / gpt-image-1.5 / gpt-image-1 / gpt-image-1-mini
# OPENAI_IMAGE_MODEL=gpt-image-2

# === NovelAI v4.5 (generate_image_nai 用,動漫風 + 香香不擋) ===
# 需 NovelAI 訂閱(建議 Opus),到帳號設定拿 Persistent API Token(前綴 pst-)。
NOVELAI_TOKEN=pst-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# NOVELAI_MODEL=nai-diffusion-4-5-full

# === GitHub mirror (optional but strongly recommended) ===
# Generated images are pushed to this repo so URLs stay permanent.
# Token needs Contents: Read+Write scope (fine-grained PAT recommended).
GITHUB_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_OWNER=cheche20250831-alt
GITHUB_REPO=my-ai-memory
# GITHUB_IMAGE_DIR=generated_images

# === Optional ===
# Override LoRA URL if a newer chechewolf is trained:
# CHECHE_LORA_URL=https://v3b.fal.media/files/b/.../pytorch_lora_weights.safetensors

# Transport: sse (default for HTTP hosting) or stdio (for local Claude Desktop)
# MCP_TRANSPORT=sse

# Port for SSE server (Zeabur auto-injects this)
# PORT=8000
